    {
      "name": "Delete Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Guard Check: Ensure we have a valid, active variable target to delete",
              "pm.test(\"Prerequisite Verification: Active target ID context found\", function () {",
              "    pm.expect(pm.collectionVariables.has(\"extracted_product_id\")).to.be.true;",
              "});",
              "",
              "if (pm.collectionVariables.has(\"extracted_product_id\")) {",
              "    const activeId = pm.collectionVariables.get(\"extracted_product_id\");",
              "",
              "    // 2. Comprehensive Status Code Assertion",
              "    pm.test(\"Database record purged successfully - Status code is valid\", function () {",
              "        // 204 No Content is the standard enterprise REST response for a successful deletion.",
              "        // 200 OK or 404 Not Found are accepted fallback codes for clean sandbox automation tracking.",
              "        pm.expect(pm.response.code).to.be.oneOf([200, 204, 404]);",
              "    });",
              "",
              "    // 3. Post-Deletion Memory Cleanup (Garbage Collection)",
              "    // Wipe the variable from your collection memory space so subsequent loops don't reference stale data.",
              "    pm.collectionVariables.unset(\"extracted_product_id\");",
              "    console.log(`[DEVOPS CLEANUP COMPLETED]: Purged variable extracted_product_id tracking contexts for ID: ${activeId}`);",
              "",
              "    // 4. Verification Check against Error Payloads (If 404 was returned instead of 204)",
              "    if (pm.response.code === 404) {",
              "        const responsePayload = pm.response.json();",
              "        pm.test(\"Safe Cleanup Check: Server acknowledges resource state\", function () {",
              "            pm.expect(responsePayload).to.have.property('error');",
              "            pm.expect(responsePayload.error).to.be.oneOf([\"record_not_found\", \"resource_not_found\"]);",
              "        });",
              "    }",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
